<Window x:Class="WildlifeTrackerV3.FoodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WildlifeTrackerV3"
        mc:Ignorable="d"
        Title="Add Food" Height="400" Width="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230*"/>
            <ColumnDefinition Width="271*"/>
        </Grid.ColumnDefinitions>

        <!--- Overall grid -->
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="70*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <!-- Grid for name -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,268" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="70*"/>
            </Grid.ColumnDefinitions>

            <!-- Label for Name -->
            <Label Grid.Column="0" Name="lblName" Content="Name" FontFamily="TimesNewRoman" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1"  Name="txtFoodName" Height="20" Margin="5,0,15,0"/>
        </Grid>

        <!--GroupBox for ingredients-->
        <GroupBox Grid.Row="1" Name="gbxIngredients" Header="Add Ingredients" Margin="15,15,15,15" Padding="15" Grid.ColumnSpan="2">
            <!-- Outer grid in the ingredients group box -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="15*"/>
                    <RowDefinition Height="70*"/>
                    <RowDefinition Height="15*"/>
                </Grid.RowDefinitions>

                <!-- Grid for ingredient Name Label and TextBox -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30*"/>
                        <ColumnDefinition Width="70*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Name="lblIngredient" Content="Ingredient" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                    <TextBox Grid.Column="1" Name="txtIngredient" Height="20"/>
                </Grid>

                <!-- Grid for Add, Change and Delete buttons as well a the ListBox that will hold the ingredients -->
                <Grid Grid.Row="1" Margin="0,0,0,33" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30*"/>
                        <ColumnDefinition Width="70*"/>
                    </Grid.ColumnDefinitions>
                    <Button Name="btnAddIngredient" Content="Add" Width="60" HorizontalAlignment="Center" Margin="0,13,0,0" VerticalAlignment="Top" Click="btnAddIngredient_Click"/>
                    <Button Name="btnChangeIngredient" Content="Change" Width="60" HorizontalAlignment="Center" Margin="0,55,0,0" VerticalAlignment="Top" Click="btnChangeIngredient_Click" >
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="-0.044"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Button.RenderTransform>
                    </Button>
                    <Button Name="btnDeleteIngredient" Content="Delete" Width="60" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,95,0,0" Click="btnDeleteIngredient_Click"/>
                    <ListBox Name="lbxIngredients" Grid.ColumnSpan="2" Margin="128,0,0,-28" />

                </Grid>
            </Grid>
        </GroupBox>
        <Button Name="btnOK" Content="OK" Width="70" HorizontalAlignment="Left" Margin="140,11,0,0" Grid.Row="2" VerticalAlignment="Top" Click="btnOk_Click"/>
        <Button Name="btnCancel" Content="Cancel" Width="70" HorizontalAlignment="Left" Margin="36,11,0,0" Grid.Row="2" VerticalAlignment="Top" Grid.Column="1" Click="btnCancel_Click"/>
    </Grid>
</Window>
